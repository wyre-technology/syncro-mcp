# The @wyre-technology scope (e.g. @wyre-technology/node-syncro) is hosted on
# GitHub Packages, which requires an auth token on EVERY install (no anonymous
# reads, even for public packages). Supply a GitHub PAT with `read:packages`
# via the NODE_AUTH_TOKEN env var, e.g.
# `export NODE_AUTH_TOKEN=$(gh auth token)` before running npm install.
@wyre-technology:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
